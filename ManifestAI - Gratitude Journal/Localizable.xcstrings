    "You'll be charged on %@ unless you cancel before." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم خصم الرسوم في %@ ما لم تُلغِ الاشتراك قبل ذلك."
          }
        },
        "da" : {
          "stringUnit" : {
