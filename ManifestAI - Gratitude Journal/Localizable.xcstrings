    "Your vision board has been saved to your gallery and is ready to be set as your lock screen wallpaper!" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم حفظ لوحة رؤيتك في معرضك وهي جاهزة لتعيينها كخلفية لشاشة القفل!"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din visionstavle er blevet gemt i dit galleri og er klar til at blive brugt som din låseskærmsbaggrund!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Vision Board wurde in deiner Galerie gespeichert und kann jetzt als Sperrbildschirm festgelegt werden!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu tablero de visión se guardó en tu galería y ya puedes usarlo como fondo de pantalla de bloqueo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visiotaulusi on tallennettu galleriaasi ja valmis asetettavaksi lukitusnäytön taustakuvaksi!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton tableau de vision a été enregistré dans ta galerie et est prêt à devenir ton fond d'écran verrouillé !"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לוח החזון שלך נשמר בגלריה שלך ומוכן להיקבע כרקע למסך הנעילה!"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Papan visimu telah tersimpan di galerimu dan siap dijadikan wallpaper layar kunci!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua vision board è stata salvata nella galleria ed è pronta per essere impostata come sfondo della schermata di blocco!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ビジョンボードがギャラリーに保存されました。ロック画面の壁紙として設定できます！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비전 보드가 갤러리에 저장되었어요. 이제 잠금화면 배경으로 설정할 수 있어요!"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visjonstavlen din er lagret i galleriet og er klar til å brukes som bakgrunnsbilde på låseskjermen!"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je vision board is opgeslagen in je galerij en klaar om als schermachtergrond in te stellen!"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoja Vision Board została zapisana w galerii i jest gotowa, aby ustawić ją jako tapetę ekranu blokady!"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu quadro dos sonhos foi salvo na sua galeria e já pode ser definido como papel de parede da tela de bloqueio!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Твоя доска визуализации сохранена в галерее и готова стать обоями на экране блокировки!"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din vision board har sparats i ditt galleri och är redo att användas som bakgrundsbild på låsskärmen!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vizyon panon galerine kaydedildi ve kilit ekranı duvar kağıdın olarak ayarlanmaya hazır!"
