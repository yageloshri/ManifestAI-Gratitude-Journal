    "A soft whisper at the right moment — nothing more. You can turn it off anytime in Profile." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "همسة لطيفة في اللحظة المناسبة — لا أكثر. يمكنك إيقافها في أي وقت من الملف الشخصي."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En blid påmindelse på det rette tidspunkt — intet mere. Du kan altid slå det fra under Profil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein sanfter Hinweis zur richtigen Zeit — mehr nicht. Du kannst das jederzeit im Profil ausschalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un suave susurro en el momento justo, nada más. Puedes desactivarlo cuando quieras en Perfil."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiljainen kuiskaus oikealla hetkellä — ei muuta. Voit sammuttaa sen milloin tahansa Profiilista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un doux murmure au bon moment — rien de plus. Tu peux le désactiver à tout moment dans Profil."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לחישה עדינה ברגע הנכון — לא יותר מזה. אפשר לכבות בכל עת בפרופיל."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekadar bisikan lembut di saat yang tepat. Bisa dimatikan kapan saja di Profil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un sussurro gentile al momento giusto — nient'altro. Puoi disattivarlo quando vuoi dal Profilo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ちょうど良いタイミングで、そっと囁くような通知だけです。プロフィールからいつでもオフにできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "적절한 순간에 건네는 작은 속삭임, 그뿐이에요. 프로필에서 언제든 끌 수 있어요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En mild påminnelse i rett øyeblikk — ikke noe mer. Du kan slå det av når som helst i Profil."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een zachte fluistering op het juiste moment — meer niet. Je kunt dit altijd uitschakelen via Profiel."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delikatne przypomnienie we właściwym momencie — nic więcej. Możesz je wyłączyć w każdej chwili w Profilu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um sussurro suave na hora certa — nada além disso. Você pode desativar quando quiser em Perfil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лёгкий шёпот в нужный момент — не больше. Ты можешь отключить это в любой момент в разделе «Профиль»."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En mjuk viskning i rätt ögonblick — inget mer. Du kan stänga av det när som helst i Profil."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doğru anda usulca bir fısıltı — hepsi bu kadar. İstediğin zaman Profil'den kapatabilirsin."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chỉ là một lời nhắc nhẹ nhàng đúng lúc — không hơn. Bạn có thể tắt bất cứ lúc nào trong Hồ Sơ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恰到好处的轻声提醒，仅此而已。你可以随时在\"我的\"中关闭它。"
          }
        }
      }
    },
