    "• Can you commit to investing 3 minutes a day in yourself?" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• هل يمكنك الالتزام باستثمار 3 دقائق يوميًا لنفسك؟"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Kan du forpligte dig til at investere 3 minutter om dagen i dig selv?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Kannst du dir 3 Minuten am Tag für dich selbst versprechen?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• ¿Puedes comprometerte a invertir 3 minutos al día en ti mismo/a?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Voitko sitoutua käyttämään 3 minuuttia päivässä itseesi?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Peux-tu t'engager à t'investir 3 minutes par jour ?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• האם תוכלו להתחייב להשקיע 3 דקות ביום בעצמכם?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Bisakah kamu berkomitmen menginvestasikan 3 menit sehari untuk dirimu sendiri?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Riesci a impegnarti a dedicare 3 minuti al giorno a te stesso?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 1日3分、自分自身に投資できますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 하루 3분을 나를 위해 투자할 수 있나요?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Kan du forplikte deg til å investere 3 minutter om dagen i deg selv?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Kun jij je 3 minuten per dag aan jezelf toewijden?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Czy możesz poświęcać sobie 3 minuty dziennie?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
