    "%@, What is holding you back right now?" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@، ما الذي يعيقك الآن؟"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@, hvad holder dig tilbage lige nu?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@, was hält dich gerade zurück?"
          }
        },
