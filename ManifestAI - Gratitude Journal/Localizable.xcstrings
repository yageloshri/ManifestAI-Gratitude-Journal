    "Couldn't save to Photos — check permission in Settings. Your board was still saved in the app." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذّر الحفظ في الصور — تحقّق من الإذن في الإعدادات. لوحة رؤيتك لا تزال محفوظة في التطبيق."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunne ikke gemme i Fotos — tjek tilladelsen i Indstillinger. Din tavle blev stadig gemt i appen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speichern in Fotos fehlgeschlagen — überprüfe die Berechtigung in den Einstellungen. Dein Board wurde trotzdem in der App gespeichert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo guardar en Fotos. Revisa los permisos en Ajustes. Tu tablero se guardó igualmente en la app."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tallennus Kuviin epäonnistui — tarkista käyttöoikeudet Asetuksista. Taulusi tallennettiin silti sovellukseen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible d'enregistrer dans Photos — vérifie les autorisations dans Réglages. Ton tableau a quand même été enregistré dans l'app."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לא ניתן לשמור לאלבום התמונות — בדקו הרשאות בהגדרות. לוח החזון שלכם עדיין נשמר באפליקציה."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gagal menyimpan ke Foto — periksa izin di Pengaturan. Papan visimu tetap tersimpan di aplikasi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossibile salvare in Foto — controlla i permessi nelle Impostazioni. La tua board è comunque salvata nell'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真に保存できませんでした — 設定でアクセス許可を確認してください。ボードはアプリ内には保存されています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진에 저장하지 못했어요 — 설정에서 권한을 확인해주세요. 보드는 앱에 안전하게 저장되었어요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunne ikke lagre til Bilder — sjekk tillatelsen i Innstillinger. Tavlen ble likevel lagret i appen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opslaan naar Foto's mislukt — controleer de toestemming in Instellingen. Je bord is wel opgeslagen in de app."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie udało się zapisać w Zdjęciach — sprawdź uprawnienia w Ustawieniach. Twoja tablica została jednak zapisana w aplikacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não foi possível salvar nas Fotos — verifique a permissão em Ajustes. Seu quadro continua salvo no app."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не удалось сохранить в Фото — проверь разрешение в настройках. Доска всё равно сохранена в приложении."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunde inte spara i Foton — kontrollera behörigheten i Inställningar. Din board sparades ändå i appen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotoğraflara kaydedilemedi — Ayarlar'dan izni kontrol et. Panon yine de uygulamada kaydedildi."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không thể lưu vào Ảnh — hãy kiểm tra quyền truy cập trong Cài đặt. Bảng tầm nhìn của bạn vẫn được lưu trong ứng dụng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法保存到\"照片\"—— 请在\"设置\"中检查权限。你的愿景板仍已保存在应用内。"
          }
        }
      }
    },
