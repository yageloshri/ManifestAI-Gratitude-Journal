    "Couldn't save to Photos — check permission in Settings." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذّر الحفظ في الصور — تحقّق من الإذن في الإعدادات."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunne ikke gemme i Fotos — tjek tilladelsen i Indstillinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speichern in Fotos fehlgeschlagen — überprüfe die Berechtigung in den Einstellungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo guardar en Fotos. Revisa los permisos en Ajustes."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tallennus Kuviin epäonnistui — tarkista käyttöoikeudet Asetuksista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
