    "Create your first Vision Board to start\nmanifesting your dreams." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنشئ لوحة رؤيتك الأولى لتبدأ\nفي تجسيد أحلامك."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opret din første visionstavle for at\nmanifestere dine drømme."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erstelle dein erstes Vision Board und beginne,\ndeine Träume zu manifestieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crea tu primer tablero de visión para empezar\na manifestar tus sueños."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Luo ensimmäinen visiotaulusi ja ala\nmanifestoida unelmiasi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crée ton premier tableau de vision pour commencer\nà manifester tes rêves."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "צרו את לוח החזון הראשון שלכם כדי להתחיל\nלהגשים את החלומות שלכם."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buat Vision Board pertamamu untuk mulai\nmewujudkan mimpimu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crea la tua prima Vision Board per iniziare\na manifestare i tuoi sogni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最初のビジョンボードを作成して\n夢を引き寄せましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "첫 비전 보드를 만들고\n꿈을 현실로 만들어보세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opprett din første visjonstavle for å begynne\nå manifestere drømmene dine."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maak je eerste Vision Board en begin\nmet het manifesteren van je dromen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utwórz swoją pierwszą Vision Board i zacznij\nmanifestować swoje marzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crie seu primeiro Quadro dos Sonhos para começar\na manifestar seus sonhos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Создай свою первую доску визуализации, чтобы начать\nманифестировать мечты."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skapa din första Vision Board för att börja\nmanifestera dina drömmar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hayallerini manifest etmeye başlamak için\nilk Vizyon Panonu oluştur."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tạo Bảng Tầm Nhìn đầu tiên để bắt đầu\nhiện thực hóa ước mơ của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "创建你的第一块愿景板，\n开始显化你的梦想。"
          }
        }
      }
    },
