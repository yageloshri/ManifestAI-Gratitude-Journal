    "Neuroscience shows that practicing gratitude for 21 days physically rewires your brain." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُظهر علم الأعصاب أن ممارسة الامتنان لمدة 21 يومًا تعيد فعليًا تشكيل دماغك."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neurovidenskab viser, at det at praktisere taknemmelighed i 21 dage fysisk omprogrammerer din hjerne."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Neurowissenschaft zeigt: 21 Tage Dankbarkeit verändern buchstäblich dein Gehirn."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La neurociencia demuestra que practicar la gratitud durante 21 días reconecta físicamente tu cerebro."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neurotiede osoittaa, että kiitollisuuden harjoittaminen 21 päivän ajan uudelleenjohdottaa aivosi fyysisesti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les neurosciences montrent que pratiquer la gratitude pendant 21 jours reconfigure physiquement ton cerveau."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מדעי המוח מראים שתרגול הכרת תודה במשך 21 יום משנה פיזית את מבנה המוח."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neurosains menunjukkan bahwa berlatih syukur selama 21 hari secara fisik membentuk ulang otakmu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le neuroscienze dimostrano che praticare la gratitudine per 21 giorni riprogramma fisicamente il tuo cervello."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "脳科学によると、21日間感謝を実践することで脳の構造そのものが変化します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신경과학에 따르면 21일간 감사를 실천하면 뇌 구조가 실제로 바뀐다고 해요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nevrovitenskap viser at å praktisere takknemlighet i 21 dager fysisk omprogrammerer hjernen din."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neurowetenschap toont aan dat 21 dagen dankbaarheid beoefenen je brein fysiek herbedraadt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neuronauka pokazuje, że praktykowanie wdzięczności przez 21 dni fizycznie przebudowuje Twój mózg."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A neurociência mostra que praticar gratidão por 21 dias reconecta fisicamente seu cérebro."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нейронаука доказывает, что практика благодарности в течение 21 дня физически перестраивает твой мозг."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neurovetenskap visar att tacksamhetsövning i 21 dagar fysiskt omformar din hjärna."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nörobilim, 21 gün boyunca minnettarlık pratiği yapmanın beynini fiziksel olarak yeniden yapılandırdığını gösteriyor."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khoa học thần kinh cho thấy thực hành lòng biết ơn trong 21 ngày sẽ tái cấu trúc não bộ bạn về mặt sinh học."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "神经科学表明，坚持感恩练习21天能从生理上重塑你的大脑。"
          }
        }
      }
    },
