    "Your daily numerology, streak, and affirmation at a glance.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أرقامك اليومية وسلسلة أيامك وتأكيدك في لمحة واحدة."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din daglige numerologi, stribe og bekræftelse på et øjeblik."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine tägliche Numerologie, Serie und Affirmation auf einen Blick."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu numerología diaria, tu racha y tu afirmación de un vistazo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Päivittäinen numerologiasi, putkesi ja affirmaatiosi yhdellä silmäyksellä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta numérologie du jour, ta série et ton affirmation en un coup d'œil."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הנומרולוגיה היומית, הרצף והאפירמציה שלך במבט אחד."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Numerologi harian, hari beruntun, dan afirmasimu sekilas pandang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua numerologia quotidiana, serie e affermazione in un colpo d'occhio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デイリー数秘術、連続記録、アファメーションを一目で確認。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매일의 수비학, 연속 기록, 확언을 한눈에 확인하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Din daglige nummerologi, rekke og bekreftelse på et blikk."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jouw dagelijkse numerologie, reeks en affirmatie in één oogopslag."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoja dzienna numerologia, passa i afirmacja w jednym miejscu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua numerologia diária, sequência e afirmação em um só lugar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Твоя ежедневная нумерология, серия дней и аффирмация — в одном взгляде."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din dagliga numerologi, streak och affirmation på en snabb överblick."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Günlük numerolojini, serini ve olumlamanı tek bakışta gör."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xem nhanh thần số học hằng ngày, chuỗi ngày và lời khẳng định của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一目了然地查看你的每日数字命理、连续记录和肯定语。"
          }
        }
      }
    }
  },
  "version": "1.0"
}